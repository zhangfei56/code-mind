{
  "name": "code-mind-vscode-extension",
  "displayName": "Code Mind",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onCommand:code-mind.explainCurrentFile",
    "onCommand:code-mind.reviewCurrentDiff",
    "onCommand:code-mind.fixSelectedCode"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "code-mind.explainCurrentFile",
        "title": "Agent: Explain Current File"
      },
      {
        "command": "code-mind.reviewCurrentDiff",
        "title": "Agent: Review Current Diff"
      },
      {
        "command": "code-mind.fixSelectedCode",
        "title": "Agent: Fix Selected Code"
      }
    ]
  }
}
