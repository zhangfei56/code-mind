{
  "name": "@code-mind/execution",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    },
    "./tools/*": {
      "types": "./dist/tools/*.d.ts",
      "import": "./dist/tools/*.js"
    },
    "./mcp/*": {
      "types": "./dist/mcp/*.d.ts",
      "import": "./dist/mcp/*.js"
    },
    "./services/*": {
      "types": "./dist/services/*.d.ts",
      "import": "./dist/services/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@code-mind/security": "workspace:*",
    "@code-mind/shared": "workspace:*",
    "@code-mind/workspace": "workspace:*",
    "typescript": "^5.9.3"
  }
}
