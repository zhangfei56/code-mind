{
  "name": "@code-mind/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    },
    "./agent/*": {
      "types": "./dist/agent/*.d.ts",
      "import": "./dist/agent/*.js"
    },
    "./agent/runtime/*": {
      "types": "./dist/agent/runtime/*.d.ts",
      "import": "./dist/agent/runtime/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@code-mind/capabilities": "workspace:*",
    "@code-mind/context": "workspace:*",
    "@code-mind/execution": "workspace:*",
    "@code-mind/observability": "workspace:*",
    "@code-mind/security": "workspace:*",
    "@code-mind/session": "workspace:*",
    "@code-mind/shared": "workspace:*",
    "@code-mind/verify": "workspace:*",
    "@code-mind/workspace": "workspace:*"
  }
}
